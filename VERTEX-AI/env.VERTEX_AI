# ============================================================================
# GOOGLE CLOUD / VERTEX AI - CONFIGURATION
# ============================================================================
# Ces variables remplacent la configuration Gemini API précédente

# Identifiants GCP
GOOGLE_CLOUD_PROJECT_ID=scan1-comptaflow
GOOGLE_CLOUD_PROJECT_NUMBER=288805151479

# Localisation Vertex AI
VERTEX_AI_LOCATION=europe-west2
VERTEX_AI_LOCATION_FALLBACK=us-central1

# Modèle Gemini via Vertex AI
VERTEX_AI_MODEL=gemini-2.5-flash
VERTEX_AI_MODEL_FALLBACK=gemini-1.5-pro

# Paramètres génération
VERTEX_AI_TEMPERATURE=0.2
VERTEX_AI_MAX_TOKENS=4096
VERTEX_AI_TOP_P=0.95
VERTEX_AI_TOP_K=40

# Timeout API (secondes)
VERTEX_AI_TIMEOUT_SECONDS=120

# Authentification
# NOTE: Utiliser ADC (Application Default Credentials) via gcloud
# NO PAS DE CLÉ API EN DUR
# Configuration : gcloud auth application-default login
# Plus d'infos : https://cloud.google.com/docs/authentication/application-default-credentials

# Document AI (optionnel, pour OCR avancé)
DOCUMENT_AI_PROCESSOR_ID=projects/288805151479/locations/europe-west2/processors/454307984c2f6cd7
DOCUMENT_AI_LOCATION=europe-west2

# Cloud Storage (optionnel, archivage factures)
GOOGLE_CLOUD_STORAGE_BUCKET=gs://bucket_flow_ai
GOOGLE_CLOUD_STORAGE_PATH_ORIGINALS=facture_image/
GOOGLE_CLOUD_STORAGE_PATH_PROCESSED=facture_processed/

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Mode IA (vertex_ai pour Vertex, gemini pour API Gemini direct)
COMPTAFLOW_IA_MODE=vertex_ai

# Seuil de confiance minimum (0-1)
# Si confiance < seuil → Facture rejetée
COMPTAFLOW_CONFIDENCE_THRESHOLD=0.70

# Logging
COMPTAFLOW_LOG_IA_REQUESTS=true
COMPTAFLOW_LOG_IA_RESPONSES=true

# Métier
COMPTAFLOW_DEFAULT_TVA_RATE=18
COMPTAFLOW_COUNTRY_CODE=CI
COMPTAFLOW_ACCOUNTING_STANDARD=SYSCOHADA

# ============================================================================
# LARAVEL STANDARDS
# ============================================================================

APP_NAME=ComptaFlow
APP_ENV=production
APP_DEBUG=false
APP_URL=https://votre-domaine.com
APP_KEY=

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=comptaflow
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=redis
SESSION_DRIVER=database
QUEUE_CONNECTION=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================================
# REMOVED / DEPRECATED
# ============================================================================

# ANCIEN : GEMINI_API_KEY=... 
# À SUPPRIMER - Remplacé par ADC + Vertex AI
# Les clés API en dur ne sont plus utilisées

# ANCIEN : VISION_API_KEY=...
# À SUPPRIMER - Vision API remplacée par Document AI (optionnel)
